---
import { Image } from "astro:assets";
import profile from "../data/profile.json";
import portrait from "../assets/profile.png";

type ProfileData = typeof profile & {
  introText?: string;
  location?: string;
  role?: string;
  portraitAlt?: string;
};

const profileData = profile as ProfileData;
const profileEyebrow = [profileData.role, profileData.location].filter(Boolean).join(" / ");

const socialLinks = [
  {
    label: "GitHub",
    href: profileData.githubUrl,
    iconPath:
      "M12 2C6.48 2 2 6.58 2 12.26c0 4.53 2.87 8.37 6.84 9.73.5.1.68-.22.68-.49v-1.9c-2.78.62-3.37-1.22-3.37-1.22-.45-1.18-1.11-1.5-1.11-1.5-.91-.64.07-.63.07-.63 1 .07 1.53 1.06 1.53 1.06.9 1.57 2.36 1.12 2.94.86.09-.67.35-1.12.63-1.38-2.22-.26-4.56-1.14-4.56-5.06 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.71 0 0 .84-.28 2.75 1.05A9.35 9.35 0 0 1 12 6.98c.85 0 1.7.12 2.5.34 1.9-1.33 2.74-1.05 2.74-1.05.55 1.41.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.93-2.34 4.8-4.57 5.05.36.32.68.95.68 1.92v2.85c0 .27.18.59.69.49A10.06 10.06 0 0 0 22 12.26C22 6.58 17.52 2 12 2Z"
  },
  {
    label: "Email",
    href: `mailto:${profileData.email}`,
    iconPath:
      "M4 5h16c1.1 0 2 .9 2 2v10a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V7c0-1.1.9-2 2-2Zm8 7.35L4.8 7H4v.8l8 5.95 8-5.95V7h-.8L12 12.35Z"
  },
  {
    label: "LinkedIn",
    href: profileData.linkedinUrl,
    iconPath:
      "M4.98 3.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5ZM3 9.75h4v10.5H3V9.75Zm6.25 0h3.83v1.44h.05c.53-1 1.84-1.9 3.78-1.9 4.04 0 4.79 2.66 4.79 6.12v4.84h-4v-4.29c0-1.02-.02-2.34-1.43-2.34-1.43 0-1.65 1.12-1.65 2.27v4.36h-4V9.75Z"
  }
];
---

<section class="about-section" id="about" aria-labelledby="about-title">
  <div class="profile-heading">
    <Image
      class="profile-photo"
      src={portrait}
      alt={profileData.portraitAlt ?? "Portrait of Dimitris Mylonas"}
      width={128}
      height={128}
      loading="eager"
    />

    <div>
      {profileEyebrow && <p class="eyebrow">{profileEyebrow}</p>}
      <h1 id="about-title">{profileData.name}</h1>
    </div>
  </div>

  <p class="hero-copy">{profileData.introText}</p>

  <div class="social-links" aria-label="Profile links">
    {
      socialLinks.map((socialLink) => (
        <a href={socialLink.href} aria-label={socialLink.label} title={socialLink.label}>
          <svg aria-hidden="true" viewBox="0 0 24 24">
            <path d={socialLink.iconPath}></path>
          </svg>
          <span>{socialLink.label}</span>
        </a>
      ))
    }
  </div>
</section>
