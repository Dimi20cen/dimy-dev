---
import "../styles/global.css";

const {
  title = "Dimitris | AI Engineer",
  description = "Portfolio of Dimitris, an AI engineer focused on practical software, backend systems, and human-friendly tools."
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f7f4ef" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
